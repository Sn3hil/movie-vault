    "typecheck": "bun run tsc --noEmit"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
